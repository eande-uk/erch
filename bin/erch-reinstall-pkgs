#!/bin/bash

# erch:summary=Reinstall all default erch packages from the stable channel
# erch:requires-sudo=true

set -e

# Reinstall all default erch packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
erch-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$ERCH_PATH/install/erch-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
