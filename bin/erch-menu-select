#!/bin/bash

# erch:summary=Pick one option with Walker
# erch:group=menu
# erch:name=select
# erch:args=prompt option... [-- walker args...]
# erch:examples=erch menu select Format jpg png|erch-menu-select Resolution 4k 1080p 720p -- --width 400

set -euo pipefail

if (( $# < 2 )); then
  echo "Usage: erch-menu-select <prompt> <option>... [-- walker args...]" >&2
  exit 1
fi

prompt="$1"
shift

options=()
walker_args=()

while (( $# > 0 )); do
  if [[ $1 == "--" ]]; then
    shift
    walker_args=("$@")
    break
  fi

  options+=("$1")
  shift
done

if (( ${#options[@]} == 0 )); then
  echo "Usage: erch-menu-select <prompt> <option>... [-- walker args...]" >&2
  exit 1
fi

printf '%s\n' "${options[@]}" | erch-launch-walker --dmenu --width 295 --minheight 1 --maxheight 300 -p "$prompt…" "${walker_args[@]}" 2>/dev/null
