#!/bin/bash

# erch:summary=Apply an erch theme
# erch:args=<theme-name>
# erch:examples=erch theme list | erch theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: erch-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/erch/current/theme"
NEXT_THEME_PATH="$HOME/.config/erch/current/next-theme"
USER_THEMES_PATH="$HOME/.config/erch/themes"
ERCH_THEMES_PATH="$ERCH_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $ERCH_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$ERCH_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  erch-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
erch-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/erch/current/theme.name"

# Change background with theme
if [[ $ERCH_THEME_SKIP_BACKGROUND != "1" ]]; then
  erch-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  erch-restart-waybar
fi
erch-restart-swayosd
erch-restart-terminal
erch-restart-hyprctl
erch-restart-btop
erch-restart-opencode
erch-restart-mako
erch-restart-helix

# Change app-specific themes
erch-theme-set-foot
erch-theme-set-gnome
erch-theme-set-browser
erch-theme-set-vscode
erch-theme-set-obsidian
erch-theme-set-keyboard

# Call hook on theme set
erch-hook theme-set "$THEME_NAME" >/dev/null
