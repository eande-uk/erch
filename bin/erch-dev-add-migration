#!/bin/bash

# erch:summary=Creates a new erch migration named after the unix timestamp of the last commit.

cd ~/.local/share/erch
migration_file="$HOME/.local/share/erch/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ $1 != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
