#!/bin/bash
# omarchy:summary=Restore displays and brightness after idle
# omarchy:group=os-conf
# omarchy:name=idle-resume
# omarchy:examples=omarchy os-conf idle-resume
# Called by hypridle when activity resumes.

set -euo pipefail

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Restore displays and brightness after idle"; exit 0; }

hyprctl dispatch dpms on >/dev/null 2>&1
brightnessctl -r >/dev/null 2>&1
brightnessctl -rd '*::kbd_backlight' >/dev/null 2>&1
