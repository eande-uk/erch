#!/bin/bash

# erch:summary=Restore the default erch Plymouth boot theme and SDDM login screen
# erch:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/erch"

sudo find ~/.local/share/erch/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme erch

if erch-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

erch-refresh-sddm
