#!/bin/bash

# erch:summary=Launch the erch screensaver in the default terminal on the system with the correct font configuration.

if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f org.erch.screensaver && exit 0

# Allow screensaver to be turned off but also force started
if erch-toggle-enabled screensaver-off && [[ $1 != "force" ]]; then
  exit 1
fi

# Silently quit Walker on overlay
walker -q

focused=$(erch-hyprland-monitor-focused)
terminal=$(xdg-terminal-exec --print-id)

for m in $(hyprctl monitors -j | jq -r '.[] | .name'); do
  hyprctl dispatch focusmonitor $m

  case $terminal in
  *Alacritty*)
    hyprctl dispatch exec -- \
      alacritty --class=org.erch.screensaver \
      --config-file ~/.local/share/erch/default/alacritty/screensaver.toml \
      -e erch-screensaver
    ;;
  *ghostty*)
    hyprctl dispatch exec -- \
      ghostty --class=org.erch.screensaver \
      --config-file=~/.local/share/erch/default/ghostty/screensaver \
      --font-size=18 \
      -e erch-screensaver
    ;;
  *foot*)
    hyprctl dispatch exec -- \
      foot --app-id=org.erch.screensaver \
      --config="$ERCH_PATH/default/foot/screensaver.ini" \
      -e erch-screensaver
    ;;
  *kitty*)
    hyprctl dispatch exec -- \
      kitty --class=org.erch.screensaver \
      --override font_size=18 \
      --override window_padding_width=0 \
      -e erch-screensaver
    ;;
  *)
    notify-send -u low "✋  Screensaver only runs in Alacritty, Foot, Ghostty, or Kitty"
    ;;
  esac
done

hyprctl dispatch focusmonitor $focused
