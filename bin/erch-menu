#!/bin/bash

# erch:summary=Launch the erch Menu or takes a parameter to jump straight to a submenu.

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | erch-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$prompt…" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.erch.terminal "$@"
}

present_terminal() {
  erch-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  erch-launch-editor "$1"
}

hypr_config_file() {
  local name="$1"
  printf '%s/.config/hypr/%s.lua' "$HOME" "$name"
}

install() {
  present_terminal "echo 'Installing $1...'; erch-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; erch-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; erch-pkg-add $2 && sleep 2 && erch-font-set '$3'"
}

install_terminal() {
  present_terminal "erch-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; erch-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; erch-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  erch\n  Hyprland\n󰣇  Arch\n  Neovim\n󱆃  Bash") in
  *Keybindings*) erch-menu-keybindings ;;
  *erch*) erch-launch-webapp "https://learn.omacom.io/2/the-erch-manual" ;;
  *Hyprland*) erch-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) erch-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) erch-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) erch-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "󰔛  Reminder\n  Capture\n󰧸  Transcode\n  Share\n󰔎  Toggle\n  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Capture*) show_capture_menu ;;
  *Transcode*) erch-transcode || back_to show_trigger_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "󰔛  Set one\n󰔛  Show all\n󰔛  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) erch-reminder show ;;
  *"Clear all"*) erch-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(erch-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    erch-notification-send "󰔛" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(erch-menu-input "Reminder message")

  if [[ -n $message ]]; then
    erch-reminder "$minutes" "$message"
  else
    erch-reminder "$minutes"
  fi
}

show_capture_menu() {
  case $(menu "Capture" "  Screenshot\n  Screenrecord\n󰴑  Text Extraction\n󰃉  Color") in
  *Screenshot*) erch-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) erch-capture-text-extraction ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  erch-capture-screenrecording --stop-recording && exit 0

  case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio\n  With desktop + microphone audio + webcam") in
  *"With no audio") erch-capture-screenrecording ;;
  *"With desktop audio") erch-capture-screenrecording --with-desktop-audio ;;
  *"With desktop + microphone audio") erch-capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    erch-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File \n  Folder") in
  *Clipboard*) erch-menu-share clipboard ;;
  *File*) terminal bash -c "erch-menu-share file" ;;
  *Folder*) terminal bash -c "erch-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="  Vim Mode\n󱄄  Screensaver\n󰔎  Nightlight\n󱫖  Idle Lock\n󰂛  Notifications\n󰍜  Top Bar\n󱂬  Workspace Layout\n  Window Gaps\n  1-Window Ratio\n󰍹  Monitor Scaling\n  Direct Boot\n󰟵  Passwordless Sudo"

  case $(menu "Toggle" "$options") in
  *Vim*) erch hyprland toggle tiling-mode \
    --enabled-notification 'Vim mode (h/j/k/l)' \
    --disabled-notification 'Normal mode (arrows)' ;;
  *Screensaver*) erch-toggle-screensaver ;;
  *Nightlight*) erch-toggle-nightlight ;;
  *Idle*) erch-toggle-idle ;;
  *Notifications*) erch-toggle-notification-silencing ;;
  *Bar*) erch-toggle-waybar ;;
  *Layout*) erch-hyprland-workspace-layout-toggle ;;
  *Ratio*) erch-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) erch-hyprland-window-gaps-toggle ;;
  *Scaling*) erch-hyprland-monitor-scaling-cycle ;;
  *"Direct Boot"*) present_terminal erch-config-direct-boot ;;
  *"Passwordless Sudo"*) present_terminal erch-sudo-passwordless ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  local options="󰛧  Laptop Display\n 󰍹  Mirror Display"

  if erch-hw-hybrid-gpu; then
    options="$options\n  Hybrid GPU"
  fi

  if erch-hw-touchpad; then
    options="$options\n󰟸  Touchpad"
  fi

  if erch-hw-dell-xps-haptic-touchpad && erch-cmd-present dell-xps-touchpad-haptics; then
    options="$options\n󰌌  Touchpad Haptics"
  fi

  if erch-hw-touchscreen; then
    options="$options\n󰆽  Touchscreen"
  fi

  case $(menu "Toggle" "$options") in
  *Laptop*) erch-hyprland-monitor-internal toggle ;;
  *Mirror*) erch-hyprland-monitor-internal-mirror toggle ;;
  *Haptics*) show_hardware_touchpad_haptics_menu ;;
  *Touchpad*) erch-toggle-touchpad ;;
  *Touchscreen*) erch-toggle-touchscreen ;;
  *"Hybrid GPU"*) present_terminal erch-toggle-hybrid-gpu ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_touchpad_haptics_menu() {
  local current=$(dell-xps-touchpad-haptics get)
  local selected=$(menu "Touchpad Haptics" "low\nmid\nhigh" "" "$current")

  if [[ -n $selected ]]; then
    dell-xps-touchpad-haptics set "$selected"
  else
    back_to show_hardware_menu
  fi
}

show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n󰟵  Unlock\n  Font\n  Background\n󰍜  Waybar\n󰘇  Corners\n  Hyprland\n󱄄  Screensaver\n  About") in

  *Theme*) show_theme_menu ;;
  *Unlock*) erch-launch-walker -m menus:erchunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Corners*) show_style_corners_menu ;;
  *Hyprland*) open_in_editor "$(hypr_config_file looknfeel)" ;;
  *Waybar*) show_waybar_position_menu ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_style_corners_menu() {
  case $(omarchy-menu-select "Corners" "󰝣  Sharp" "󰘇  Round") in
  *Sharp*) omarchy-style-corners sharp ;;
  *Round*) omarchy-style-corners round ;;
  *) show_style_menu ;;
  esac
}

show_waybar_position_menu() {
  case $(menu "Waybar Position" "󰁝  Top\n󰁅  Bottom\n󰁍  Left\n󰁔  Right") in
  *Top*) omarchy-style-waybar-position top ;;
  *Bottom*) omarchy-style-waybar-position bottom ;;
  *Left*) omarchy-style-waybar-position left ;;
  *Right*) omarchy-style-waybar-position right ;;
  *) show_style_menu ;;
  esac
}

show_about_menu() {
  case $(menu "About" "  Edit Text\n  Set From Image\n  Restore Default") in
  *Text*) erch-branding-about text ;;
  *Image*) erch-branding-about image ;;
  *Default*) erch-branding-about reset ;;
  *) show_style_menu ;;
  esac
}

show_screensaver_menu() {
  case $(menu "Screensaver" "  Edit Text\n  Set From Image\n  Restore Default") in
  *Text*) erch-branding-screensaver text ;;
  *Image*) erch-branding-screensaver image ;;
  *Default*) erch-branding-screensaver reset ;;
  *) show_style_menu ;;
  esac
}

show_theme_menu() {
  erch-launch-walker -m menus:erchthemes --width 800 --minheight 400
}

show_background_menu() {
  erch-launch-walker -m menus:erchBackgroundSelector --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(erch-font-list)" "--width 350" "$(erch-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    erch-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile\n  System Sleep\n󰍹  Monitors"
  [[ -f ~/.config/hypr/bindings.lua ]] && options="$options\n  Keybindings"
  [[ -f ~/.config/hypr/input.lua ]] && options="$options\n  Input"
  options="$options\n  Defaults\n󰱔  DNS\n  Security\n  Config"

  case $(menu "Setup" "$options") in
  *Audio*) erch-launch-audio ;;
  *Wifi*) erch-launch-wifi ;;
  *Bluetooth*) erch-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor "$(hypr_config_file monitors)" ;;
  *Keybindings*) open_in_editor "$(hypr_config_file bindings)" ;;
  *Input*) open_in_editor "$(hypr_config_file input)" ;;
  *Defaults*) show_setup_default_menu ;;
  *DNS*) present_terminal erch-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(erch-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "󰈷  Fingerprint\n  Fido2") in
  *Fingerprint*) present_terminal erch-setup-security-fingerprint ;;
  *Fido2*) present_terminal erch-setup-security-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_default_menu() {
  case $(menu "Default" "  Browser\n  Terminal\n  Editor") in
  *Browser*) show_setup_default_browser_menu ;;
  *Terminal*) show_setup_default_terminal_menu ;;
  *Editor*) show_setup_default_editor_menu ;;
  *) show_setup_menu ;;
  esac
}

browser_desktop_exists() {
  [[ -f ~/.local/share/applications/$1 || -f ~/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

show_setup_default_browser_menu() {
  local options=""
  browser_desktop_exists chromium.desktop && options="$options  Chromium"
  browser_desktop_exists google-chrome.desktop && options="${options:+$options\n}󰊯  Chrome"
  browser_desktop_exists brave-browser.desktop && options="${options:+$options\n}󰖟  Brave"
  browser_desktop_exists brave-origin-beta.desktop && options="${options:+$options\n}󰖟  Brave Origin"
  browser_desktop_exists microsoft-edge.desktop && options="${options:+$options\n}󰇩  Edge"
  browser_desktop_exists firefox.desktop && options="${options:+$options\n}󰈹  Firefox"
  browser_desktop_exists zen.desktop && options="${options:+$options\n}󰖟  Zen"

  local current=""
  case "$(erch-default-browser)" in
  chromium) current="  Chromium" ;;
  chrome) current="󰊯  Chrome" ;;
  brave) current="󰖟  Brave" ;;
  brave-origin) current="󰖟  Brave Origin" ;;
  edge) current="󰇩  Edge" ;;
  firefox) current="󰈹  Firefox" ;;
  zen) current="󰖟  Zen" ;;
  esac

  case $(menu "Default Browser" "$options" "" "$current") in
  *Chromium*) erch-default-browser chromium ;;
  *Chrome*) erch-default-browser chrome ;;
  *"Brave Origin"*) erch-default-browser brave-origin ;;
  *Brave*) erch-default-browser brave ;;
  *Edge*) erch-default-browser edge ;;
  *Firefox*) erch-default-browser firefox ;;
  *Zen*) erch-default-browser zen ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_terminal_menu() {
  local options=""
  erch-cmd-present alacritty && options="$options  Alacritty"
  erch-cmd-present foot && options="${options:+$options\n}  Foot"
  erch-cmd-present ghostty && options="${options:+$options\n}  Ghostty"
  erch-cmd-present kitty && options="${options:+$options\n}  Kitty"

  local current=""
  case "$(erch-default-terminal)" in
  alacritty) current="  Alacritty" ;;
  foot) current="  Foot" ;;
  ghostty) current="  Ghostty" ;;
  kitty) current="  Kitty" ;;
  esac

  case $(menu "Default Terminal" "$options" "" "$current") in
  *Alacritty*) erch-default-terminal alacritty ;;
  *Foot*) erch-default-terminal foot ;;
  *Ghostty*) erch-default-terminal ghostty ;;
  *Kitty*) erch-default-terminal kitty ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_editor_menu() {
  local options=""
  erch-cmd-present nvim && options="$options  Neovim"
  erch-cmd-present code && options="${options:+$options\n}  VSCode"
  erch-cmd-present cursor && options="${options:+$options\n}  Cursor"
  erch-cmd-present zeditor && options="${options:+$options\n}  Zed"
  erch-cmd-present sublime_text && options="${options:+$options\n}  Sublime Text"
  erch-cmd-present helix && options="${options:+$options\n}  Helix"
  erch-cmd-present vim && options="${options:+$options\n}  Vim"
  erch-cmd-present emacs && options="${options:+$options\n}  Emacs"

  local current=""
  case "$(erch-default-editor)" in
  nvim) current="  Neovim" ;;
  code) current="  VSCode" ;;
  cursor) current="  Cursor" ;;
  zed | zeditor) current="  Zed" ;;
  sublime_text) current="  Sublime Text" ;;
  helix) current="  Helix" ;;
  vim) current="  Vim" ;;
  emacs) current="  Emacs" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) erch-default-editor nvim ;;
  *VSCode*) erch-default-editor code ;;
  *Cursor*) erch-default-editor cursor ;;
  *Zed*) erch-default-editor zed ;;
  *Sublime*) erch-default-editor sublime_text ;;
  *Helix*) erch-default-editor helix ;;
  *Vim*) erch-default-editor vim ;;
  *Emacs*) erch-default-editor emacs ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "  Hyprland\n  Hypridle\n  Hyprlock\n  Hyprsunset\n  Swayosd\n󰌧  Walker\n󰍜  Waybar\n󰞅  XCompose") in
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && erch-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && erch-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && erch-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && erch-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && erch-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && erch-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if erch-toggle-enabled suspend-off; then
    options="$options󰒲  Enable Suspend"
  else
    options="$options󰒲  Disable Suspend"
  fi

  if erch-hibernation-available; then
    options="$options\n󰤁  Disable Hibernate"
  else
    options="$options\n󰤁  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) erch-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal erch-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal erch-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "󰣇  Package\n󰣇  AUR\n  Web App\n  TUI\n  Service\n  Style\n󰵮  Development\n  Editor\n  Terminal\n  Browser\n󱚤  AI\n  Gaming\n󰍲  Windows") in
  *Package*) terminal erch-pkg-install ;;
  *AUR*) terminal erch-pkg-aur-install ;;
  *Web*) present_terminal erch-webapp-install ;;
  *TUI*) present_terminal erch-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *Browser*) show_install_browser_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "erch-windows-vm install" ;;
  *) show_main_menu ;;
  esac
}

show_install_browser_menu() {
  case $(menu "Install" "  Chrome\n  Edge\n  Brave\n  Brave Origin\n  Firefox\n󰖟  Zen") in
  *Chrome*) present_terminal "erch-install-browser chrome" ;;
  *Edge*) present_terminal "erch-install-browser edge" ;;
  *"Brave Origin"*) present_terminal "erch-install-browser brave-origin" ;;
  *Brave*) present_terminal "erch-install-browser brave" ;;
  *Firefox*) present_terminal "erch-install-browser firefox" ;;
  *Zen*) present_terminal "erch-install-browser zen" ;;
  *) show_install_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "  Dropbox\n  Tailscale\n󱇱  NordVPN [AUR]\n󰏖  ONCE\n󰟵  Bitwarden\n  Chromium Account") in
  *Dropbox*) present_terminal erch-install-dropbox ;;
  *Tailscale*) present_terminal erch-install-tailscale ;;
  *NordVPN*) present_terminal erch-install-nordvpn ;;
  *ONCE*) present_terminal erch-install-once ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *Chromium*) present_terminal erch-install-chromium-google-account ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "  VSCode\n  Cursor\n  Zed\n  Sublime Text\n  Helix\n  Vim\n  Emacs") in
  *VSCode*) present_terminal erch-install-vscode ;;
  *Cursor*) install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) present_terminal erch-install-zed ;;
  *Sublime*) install_and_launch "Sublime Text" "sublime-text-4" "sublime_text" ;;
  *Helix*) present_terminal erch-install-helix ;;
  *Vim*) install "Vim" "vim" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
  case $(menu "Install" "  Alacritty\n  Foot\n  Ghostty\n  Kitty") in
  *Alacritty*) install_terminal "alacritty" ;;
  *Foot*) install_terminal "foot" ;;
  *Ghostty*) install_terminal "ghostty" ;;
  *Kitty*) install_terminal "kitty" ;;
  *) show_install_menu ;;
  esac
}

show_install_ai_menu() {
  ollama_pkg=$(
    (erch-cmd-present nvidia-smi && echo ollama-cuda) ||
      (erch-cmd-present rocminfo && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "  Dictation\n󱚤  LM Studio\n󱚤  Ollama\n󱚤  Crush") in
  *Dictation*) present_terminal erch-voxtype-install ;;
  *Studio*) install "LM Studio" "lmstudio-bin" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *) show_install_menu ;;
  esac
}

