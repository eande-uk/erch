#!/bin/bash

# erch:summary=Overwrite all the user configs in ~/.config/hypr with the erch defaults.

erch-refresh-config hypr/autostart.conf
erch-refresh-config hypr/bindings.conf
erch-refresh-config hypr/input.conf
erch-refresh-config hypr/looknfeel.conf
erch-refresh-config hypr/hyprland.conf
erch-refresh-config hypr/monitors.conf
bash "$ERCH_PATH/install/config/detect-keyboard-layout.sh"
