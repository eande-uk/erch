#!/bin/bash

# erch:summary=Update erch and system packages
# erch:args=[-y]
# erch:examples=erch update | erch update -y
# erch:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $ERCH_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ERCH_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/erch-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://erch.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || erch-update-confirm; then
  erch-snapshot create || (($? == 127))
  erch-update-git
  erch-update-perform
fi
