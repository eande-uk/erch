#!/bin/bash

# erch:summary=Reinstall erch packages and reset default configs
# erch:requires-sudo=true

set -e

# Attempt to reinstall all default erch packages and reset all the default configs.

echo -e "This will reinstall all the default erch packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  erch-reinstall-git
  erch-reinstall-pkgs
  erch-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && erch-system-reboot
fi
