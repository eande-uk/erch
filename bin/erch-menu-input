#!/bin/bash

# erch:summary=Prompt for text input with Walker
# erch:group=menu
# erch:name=input
# erch:args=prompt [walker args...]
# erch:examples=erch menu input Reminder|erch-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

erch-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
