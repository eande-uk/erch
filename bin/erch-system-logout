#!/bin/bash

# erch:summary=Log out after closing application windows
# erch:examples=erch logout | erch system logout
# erch:aliases=erch logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
erch-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
