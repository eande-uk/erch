#!/bin/bash

# erch:summary=Set Hyprland, Hyprlock, Mako, and Walker corners to sharp or round
# erch:args=<sharp|round>
# erch:examples=erch style corners round | erch style corners sharp

if [[ $1 != "sharp" && $1 != "round" ]]; then
  echo "Usage: erch-style-corners <sharp|round>"
  exit 1
fi

erch-style-corners-hyprland "$1"
erch-style-corners-hyprlock "$1"
erch-style-corners-mako "$1"
erch-style-corners-walker "$1"

case $1 in
  sharp) erch-notification-send "Sharp corners enabled" -g 󰝣 ;;
  round) erch-notification-send "Round corners enabled" -g 󰘇 ;;
esac
