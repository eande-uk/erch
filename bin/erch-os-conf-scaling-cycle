#!/bin/bash
# erch:summary=Cycle display scaling across all monitors
# erch:group=os-conf
# erch:name=scaling-cycle
# erch:examples=erch os-conf scaling-cycle
# Cycles: 1.00 → 2.00 → 3.13 → 1.00

set -euo pipefail

usage() {
  cat <<EOF
erch os-conf scaling-cycle — Cycle display scaling across all monitors

Cycles through: 1.00 → 2.00 → 3.13 → 1.00

Usage:
  erch os-conf scaling-cycle
EOF
  exit 0
}

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

CURRENT=$(hyprctl monitors -j | jq -r '.[0].scale' 2>/dev/null || echo "")

case "$CURRENT" in
  1.00) NEW="2" ;;
  2.00) NEW="3.13" ;;
  3.13) NEW="1" ;;
  *)    NEW="2" ;;
esac

hyprctl monitors -j | jq -r '.[].name' | while read -r monitor; do
  hyprctl keyword monitor "$monitor,preferred,auto,$NEW" >/dev/null 2>&1
done

notify-send "󰍹  Display scaling set to ${NEW}x"
gum style --foreground "#A3BE8C" "  Scaling set to ${NEW}x"
