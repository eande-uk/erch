#!/bin/bash

# erch:summary=Send a desktop notification with erch glyph and body spacing
# erch:args=<glyph> <headline> [description] [notify-send options]
# erch:examples=erch notification send "󰔛" "Reminder" "5 minutes are up" -u critical

set -euo pipefail

if (($# < 2)); then
  echo "Usage: erch-notification-send <glyph> <headline> [description] [notify-send options]"
  exit 1
fi

glyph=$1
headline=$2
description=${3:-}
shift 2

if (($# > 0)) && [[ $1 != -* ]]; then
  shift
else
  description=""
fi

summary="$glyph    $headline"

if [[ -n $description ]]; then
  description=$(sed 's/^/      /' <<<"$description")
  notify-send "$@" "$summary" "$description"
else
  notify-send "$@" "$summary"
fi
