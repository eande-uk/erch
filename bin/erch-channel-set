#!/bin/bash

# erch:summary=Set the erch channel, which dictates what git branch and package repository is used.
# erch:args=<stable|rc|edge|dev>
# erch:requires-sudo=true

if (($# == 0)); then
  echo "Usage: erch-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") erch-branch-set "master" && erch-refresh-pacman "stable" ;;
"rc") erch-branch-set "rc" && erch-refresh-pacman "rc" ;;
"edge") erch-branch-set "master" && erch-refresh-pacman "edge" ;;
"dev") erch-branch-set "dev" && erch-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

erch-update -y
