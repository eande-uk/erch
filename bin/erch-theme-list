#!/bin/bash

# erch:summary=List available themes
# erch:examples=erch theme list | erch theme set "Tokyo Night"

{
  find ~/.config/erch/themes/ -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -printf '%f\n'
  find "$ERCH_PATH/themes/" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
} | sort -u | while read -r name; do
  echo "$name" | sed -E 's/(^|-)([a-z])/\1\u\2/g; s/-/ /g'
done
