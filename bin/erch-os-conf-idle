#!/bin/bash
# erch:summary=Lock screen and turn display off after idle
# erch:group=os-conf
# erch:name=idle
# erch:examples=erch os-conf idle
# Called by hypridle when the system has been idle.

set -euo pipefail

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Lock screen and turn display off after delay"; exit 0; }

if ! loginctl lock-session 2>/dev/null; then
  erch-system-lock 2>/dev/null || hyprctl dispatch exit
fi

(
  sleep 10
  pidof hyprlock >/dev/null || exit 0
  brightnessctl -sd '*::kbd_backlight' set 0 >/dev/null 2>&1
  hyprctl dispatch dpms off >/dev/null 2>&1
) &
disown
