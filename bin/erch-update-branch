#!/bin/bash

# erch:summary=Switch erch branches and update from the selected branch
# erch:args=<branch>

set -e

if (($# == 0)); then
  echo "Usage: erch-update-branch [master|dev]"
  exit 1
fi

branch="$1"

# Snapshot before switching branch
erch-snapshot create || (( $? == 127 ))

if ! git -C "$ERCH_PATH" diff --quiet || ! git -C "$ERCH_PATH" diff --cached --quiet; then
  stashed=true
  git -C "$ERCH_PATH" stash push -u -m "Autostash before switching to $branch"
else
  stashed=false
fi

# Switch branches
git -C "$ERCH_PATH" switch "$branch"

# Reapply stash if we made one
if [[ $stashed == "true" ]]; then
  if ! git -C "$ERCH_PATH" stash pop; then
    echo "⚠️ Conflicts when applying stash — stash kept"
  fi
fi

# Update the system from the new branch
erch-update-perform
