#!/bin/bash

# erch:summary=Set the branch for erch's git repository.
# erch:args=<master|rc|dev>

if (($# == 0)); then
  echo "Usage: erch-branch-set [master|rc|dev]"
  exit 1
else
  branch="$1"
fi

if [[ $branch != "master" && $branch != "rc" && $branch != "dev" ]]; then
  echo "Error: Invalid branch '$branch'. Must be one of: master, rc, dev"
  exit 1
fi

git -C $ERCH_PATH switch $branch
