#!/bin/bash

# erch:summary=Set the branch for erch's git repository.
# erch:args=<master>

if (($# == 0)); then
  echo "Usage: erch-branch-set [master|rc|dev]"
  exit 1
else
  branch="$1"
fi

if [[ $branch != "master" ]]; then
  echo "Error: Invalid branch '$branch'. Only 'master' is available."
  exit 1
fi

git -C $ERCH_PATH switch $branch
