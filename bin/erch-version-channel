#!/bin/bash

# erch:summary=Print the active erch mirror and package channel

if grep -q "https://stable-mirror.erch.org/" /etc/pacman.d/mirrorlist; then
  mirror="stable"
elif grep -q "https://rc-mirror.erch.org/" /etc/pacman.d/mirrorlist; then
  mirror="rc"
elif grep -q "https://mirror.erch.org/" /etc/pacman.d/mirrorlist; then
  mirror="edge"
else
  mirror="unknown"
fi

if grep -q "https://pkgs.erch.org/stable/" /etc/pacman.conf; then
  pkgs="stable"
elif grep -q "https://pkgs.erch.org/edge/" /etc/pacman.conf; then
  pkgs="edge"
elif grep -q "https://pkgs.erch.org/rc/" /etc/pacman.conf; then
  pkgs="rc"
else
  pkgs="unknown"
fi

if [[ $mirror == $pkgs ]]; then
  echo $mirror
else
  echo "$mirror / $pkgs"
fi
