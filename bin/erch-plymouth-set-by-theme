#!/bin/bash

# erch:summary=Set the Plymouth boot theme from an erch theme
# erch:args=<theme-name>
# erch:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via erch-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: erch-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/erch/themes/$theme ]]; then
  theme_dir=~/.config/erch/themes/$theme
else
  theme_dir="$ERCH_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec erch-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
