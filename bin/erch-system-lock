#!/bin/bash

# erch:summary=Lock the computer and turn off the display
# erch:group=system
# erch:name=lock
# erch:examples=erch system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    erch-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.erch.screensaver

if [[ ${ERCH_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    erch-brightness-keyboard off
    erch-brightness-display off
  ) &
fi
